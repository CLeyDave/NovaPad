<UserControl x:Class="NovaPad.Overlay.Widgets.DebugWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto">
    <Border Background="#CC111111"
            BorderBrush="#333333"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12,8">
        <StackPanel>
            <TextBlock Text="DEBUG"
                       FontSize="9" FontWeight="Bold"
                       Foreground="#FF9800"
                       Margin="0,0,0,4"/>
            <TextBlock x:Name="FpsText"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="#AAAAAA"/>
            <TextBlock x:Name="LatencyText"
                       FontSize="11"
                       Foreground="#888888"/>
            <TextBlock x:Name="RenderText"
                       FontSize="11"
                       Foreground="#888888"/>
        </StackPanel>
    </Border>
</UserControl>
