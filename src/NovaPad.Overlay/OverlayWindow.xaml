<Window x:Class="NovaPad.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NovaPad.Overlay.Widgets"
        xmlns:panels="clr-namespace:NovaPad.Overlay.Views"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Left="0" Top="0"
        Width="{x:Static SystemParameters.PrimaryScreenWidth}"
        Height="{x:Static SystemParameters.PrimaryScreenHeight}">
    <Grid x:Name="RootGrid" IsHitTestVisible="False">
        <views:HudControl x:Name="HudWidget"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top"
                          Margin="0,12,12,0"
                          IsHitTestVisible="False"/>
        <panels:ExpandedPanel x:Name="ExpandedWidget"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             IsHitTestVisible="False"
                             Visibility="Collapsed"/>
        <StackPanel x:Name="WidgetContainer"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="12,12,0,0"
                    Orientation="Horizontal"
                    IsHitTestVisible="False"/>
        <StackPanel x:Name="NotificationContainer"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,24,80"
                    IsHitTestVisible="False"/>
    </Grid>
</Window>