<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:NovaPad.WPF.Converters">

    <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    <conv:BoolToVisibilityConverter x:Key="BoolToVisInverted" IsInverted="True"/>
    <conv:StringToVisibilityConverter x:Key="StringToVis"/>
    <conv:BatteryLevelToColorConverter x:Key="BatteryColor"/>
    <conv:ConnectionTypeToIconConverter x:Key="ConnectionIcon"/>
    <conv:LogLevelToColorConverter x:Key="LogColor"/>
    <conv:PercentageConverter x:Key="Percentage"/>
    <conv:SidebarWidthConverter x:Key="SidebarWidthConverter"/>
    <conv:ConvertidorEstadoEnlace x:Key="OverlayStatus"/>
    <conv:StickPosConverter x:Key="StickPosConverter"/>
    <conv:ButtonActiveBgConverter x:Key="ButtonActiveBg"/>
    <conv:ButtonActiveFgConverter x:Key="ButtonActiveFg"/>
    <conv:BatteryPercentColorConverter x:Key="BatteryPercentColor"/>
    <conv:RatioToGridLengthConverter x:Key="RatioToFillConverter"/>
    <conv:InverseRatioToGridLengthConverter x:Key="RatioToGapConverter"/>

</ResourceDictionary>
