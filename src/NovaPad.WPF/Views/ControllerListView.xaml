<UserControl x:Class="NovaPad.WPF.Views.ControllerListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NovaPad.WPF.ViewModels"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DataContext="{d:DesignInstance vm:ControllerListViewModel}">

    <ScrollViewer Style="{StaticResource ModernScrollViewer}" Padding="24">
        <StackPanel>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Mandos Conectados"
                           Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center"/>

            </Grid>

            <ItemsControl ItemsSource="{Binding Controllers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ControllerItem">
                        <Border Style="{StaticResource ControllerCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Controller Icon -->
                                <Border Grid.Column="0" Width="56" Height="56"
                                        CornerRadius="14" Background="{DynamicResource SurfaceAltBrush}"
                                        VerticalAlignment="Center">
                                    <Path Data="{StaticResource GamepadIcon}"
                                          Stroke="{StaticResource PrimaryBrush}"
                                          StrokeThickness="1.8" Fill="Transparent"
                                          Stretch="Uniform" Width="28" Height="28"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Name, Type, Connection -->
                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding Type}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <Ellipse Width="3" Height="3" Fill="{DynamicResource TextDisabledBrush}"
                                                 Margin="8,5,8,0"/>
                                        <TextBlock Text="{Binding ConnectionType}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <Ellipse Width="3" Height="3" Fill="{DynamicResource TextDisabledBrush}"
                                                 Margin="8,5,8,0"/>
                                        <TextBlock Text="{Binding PollingRate}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Status Right -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                Visibility="{Binding HasBattery, Converter={StaticResource BoolToVis}}">
                                        <Path Data="{StaticResource BatteryChargingIcon}"
                                              Stroke="{Binding BatteryLevel, Converter={StaticResource BatteryColor}}"
                                              StrokeThickness="1.8" Fill="Transparent"
                                              Stretch="Uniform" Width="14" Height="14"
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding BatteryLevel, StringFormat={}{0}%}"
                                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="4,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Latency}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,4,0,0" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
