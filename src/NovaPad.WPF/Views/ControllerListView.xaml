<UserControl x:Class="NovaPad.WPF.Views.ControllerListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NovaPad.WPF.ViewModels"
             xmlns:services="clr-namespace:NovaPad.WPF.Services"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DataContext="{d:DesignInstance vm:ControllerListViewModel}">

    <ScrollViewer Style="{StaticResource ModernScrollViewer}" Padding="24">
        <StackPanel>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Controllers_Title]}"
                           Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center"/>

            </Grid>

            <ItemsControl ItemsSource="{Binding Controllers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ControllerItem">
                        <Border Style="{StaticResource ControllerCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Controller Icon -->
                                <Border Grid.Column="0" Width="56" Height="56"
                                        CornerRadius="14" Background="{DynamicResource SurfaceAltBrush}"
                                        VerticalAlignment="Center">
                                    <Path Data="{StaticResource GamepadIcon}"
                                          Stroke="{StaticResource PrimaryBrush}"
                                          StrokeThickness="1.8" Fill="Transparent"
                                          Stretch="Uniform" Width="28" Height="28"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Name, Type, Connection + Inline Rename -->
                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <!-- Display name -->
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}"/>
                                    <!-- Edit name TextBox -->
                                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14" FontWeight="SemiBold"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource SurfaceAltBrush}"
                                             BorderBrush="{StaticResource PrimaryBrush}"
                                             BorderThickness="1"
                                             Padding="4,2"
                                             MinWidth="120"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                             KeyDown="OnRenameTextBoxKeyDown"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding Type}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <Ellipse Width="3" Height="3" Fill="{DynamicResource TextDisabledBrush}"
                                                 Margin="8,5,8,0"/>
                                        <TextBlock Text="{Binding ConnectionType}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <Ellipse Width="3" Height="3" Fill="{DynamicResource TextDisabledBrush}"
                                                 Margin="8,5,8,0"/>
                                        <TextBlock Text="{Binding PollingRate}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Status Right + Actions -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                Visibility="{Binding HasBattery, Converter={StaticResource BoolToVis}}">
                                        <Path Data="{StaticResource BatteryChargingIcon}"
                                              Stroke="{Binding BatteryLevel, Converter={StaticResource BatteryColor}}"
                                              StrokeThickness="1.8" Fill="Transparent"
                                              Stretch="Uniform" Width="14" Height="14"
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding BatteryLevel, StringFormat={}{0}%}"
                                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="4,0,0,0"/>
                                    </StackPanel>

                                    <!-- Edit-mode buttons -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                Margin="0,4,0,0"
                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                          <Button Content="Guardar"
                                                  Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.SaveRenameControllerCommand}"
                                                  CommandParameter="{Binding}"
                                                  Style="{StaticResource SmallActionButtonStyle}"
                                                  Margin="0,0,4,0"
                                                   Background="{StaticResource PrimaryBrush}"
                                                   Foreground="White"/>
                                          <Button Content="Cancelar"
                                                   Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.CancelRenameControllerCommand}"
                                                   CommandParameter="{Binding}"
                                                   Style="{StaticResource SmallActionButtonStyle}"
                                                   Background="{DynamicResource SurfaceAltBrush}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>

                                    <!-- Default action buttons -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                Margin="0,4,0,0"
                                                Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}">
                                          <Button Content="Renombrar"
                                                  Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.RenameControllerCommand}"
                                                  CommandParameter="{Binding}"
                                                  Style="{StaticResource SmallActionButtonStyle}"
                                                  Margin="0,0,4,0"
                                                   Background="{DynamicResource SurfaceAltBrush}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                          <Button Content="Desconectar"
                                                  Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.DisconnectControllerCommand}"
                                                  CommandParameter="{Binding}"
                                                  Style="{StaticResource SmallActionButtonStyle}"
                                                  Background="#44EF5350"
                                                  Foreground="#EF5350"
                                                  BorderThickness="1" BorderBrush="#44EF5350"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Latency}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,4,0,0" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>