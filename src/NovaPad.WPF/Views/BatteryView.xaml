<UserControl x:Class="NovaPad.WPF.Views.BatteryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NovaPad.WPF.ViewModels"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DataContext="{d:DesignInstance vm:BatteryViewModel}">

    <ScrollViewer Style="{StaticResource ModernScrollViewer}" Padding="24">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <Border Width="40" Height="40" CornerRadius="10"
                        Background="{DynamicResource SurfaceAltBrush}"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                    <Path Data="{StaticResource BatteryFullIcon}"
                          Stroke="{StaticResource PrimaryBrush}"
                          StrokeThickness="1.8" Fill="Transparent"
                          Stretch="Uniform" Width="22" Height="22"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="BATERÍA DE MANDOS" Style="{StaticResource SectionTitleStyle}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <ItemsControl ItemsSource="{Binding Controllers}"
                          Visibility="{Binding HasControllers, Converter={StaticResource BoolToVis}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:BatteryItem">
                        <Border Style="{StaticResource CardStyle}" Width="220" Margin="0,0,16,16">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>

                                <Grid Width="110" Height="180" HorizontalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Width="28" Height="10"
                                            CornerRadius="5,5,0,0"
                                            HorizontalAlignment="Center"
                                            Background="{DynamicResource TextSecondaryBrush}"/>

                                    <Border Grid.Row="1" CornerRadius="12"
                                            BorderBrush="{DynamicResource TextSecondaryBrush}"
                                            BorderThickness="3"
                                            Background="{DynamicResource SurfaceAltBrush}"
                                            Padding="5">
                                        <Grid>
                                            <Border CornerRadius="7"
                                                    VerticalAlignment="Bottom"
                                                    HorizontalAlignment="Stretch"
                                                    Height="{Binding FillHeight}"
                                                    Background="{Binding BarColor}"/>
                                        </Grid>
                                    </Border>

                                    <TextBlock Grid.Row="1"
                                               Text="{Binding PercentText}"
                                               FontSize="28" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <TextBlock Text="{Binding ChargingText}"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{Binding BarColor}"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="No hay mandos conectados."
                       FontSize="14" Foreground="{DynamicResource TextDisabledBrush}"
                       HorizontalAlignment="Center" Margin="0,40,0,0"
                       Visibility="{Binding HasControllers, Converter={StaticResource BoolToVisInverted}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
