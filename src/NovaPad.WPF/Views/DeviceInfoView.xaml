<UserControl x:Class="NovaPad.WPF.Views.DeviceInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NovaPad.WPF.ViewModels"
             xmlns:services="clr-namespace:NovaPad.WPF.Services"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DataContext="{d:DesignInstance vm:DeviceInfoViewModel}">

    <ScrollViewer Style="{StaticResource ModernScrollViewer}" Padding="24">
        <StackPanel MaxWidth="640">

            <!-- Controller picker -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Title]}"
                               FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding Pool}"
                              SelectedItem="{Binding Current, Mode=TwoWay}"
                              DisplayMemberPath="EffectiveName"
                              Style="{StaticResource ModernComboBoxStyle}"/>
                </StackPanel>
            </Border>

            <!-- Detail cards when a controller is selected -->
            <StackPanel Visibility="{Binding Active, Converter={StaticResource BoolToVis}}">

                <!-- Identity -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Identity]}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDisabledBrush}"
                                   Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Name]}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Type]}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Kind}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Connection]}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Link}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,4"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Hardware -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Hardware]}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDisabledBrush}"
                                   Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_VID]}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Vendor}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_PID]}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Device}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_HIDPath]}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Hid}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="8,0,0,4" TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Firmware]}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Version}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,4"/>

                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Capabilities]}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Features}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,4"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Status]}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDisabledBrush}"
                                   Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Battery]}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,4">
                                <TextBlock Text="{Binding Power}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding ChargeLabel}" FontSize="11"
                                            Foreground="{StaticResource PrimaryBrush}" Margin="6,2,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Latency]}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Response}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Frequency]}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Rate}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,4"/>

                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Signal]}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Strength}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,4"/>

                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Active]}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Online}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,4"/>
                        </Grid>

                        <Grid Height="8" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Charge, Converter={StaticResource RatioToFillConverter}}"/>
                                <ColumnDefinition Width="{Binding Charge, Converter={StaticResource RatioToGapConverter}}"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" RadiusX="4" RadiusY="4"
                                       Fill="{Binding Charge, Converter={StaticResource BatteryPercentColor}}"/>
                            <Rectangle Grid.Column="1" RadiusX="4" RadiusY="4"
                                       Fill="{StaticResource PrimaryDarkBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Signal / Latency / Polling quick stats -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Signal]}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextDisabledBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Strength}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_LatencyTitle]}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextDisabledBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Response}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_FrequencyTitle]}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextDisabledBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Rate}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Empty -->
            <Border Style="{StaticResource CardStyle}"
                    Visibility="{Binding Idle, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviceInfo_Empty]}"
                           FontSize="14" Foreground="{DynamicResource TextDisabledBrush}"
                           HorizontalAlignment="Center" Margin="0,32"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>