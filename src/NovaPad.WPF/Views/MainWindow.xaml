<Window x:Class="NovaPad.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NovaPad.WPF.ViewModels"
        xmlns:tb="clr-namespace:Hardcodet.Wpf.TaskbarNotification;assembly=Hardcodet.NotifyIcon.Wpf"
        mc:Ignorable="d"
        Title="NovaPad"
        Width="1280" Height="820"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Foreground="{DynamicResource TextPrimaryBrush}"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="WindowBorder"
            Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="0"
            Effect="{StaticResource WindowShadow}">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding IsSidebarExpanded, Converter={StaticResource SidebarWidthConverter}}"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0"
                    CornerRadius="8,0,0,8">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo & Title -->
                    <Border Grid.Row="0" Padding="20,20,20,16"
                            Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="pack://application:,,,/NovaPadIcon.png"
                                   Width="40" Height="40" Stretch="Uniform"
                                   VerticalAlignment="Center"/>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center"
                                        Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="NovaPad" FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Gestor de Mandos" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,-2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Navigation Items -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding NavigationItems}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource NavButtonStyle}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                             Margin="0,8,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:NavigationItem">
                                <Grid Height="36">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" Data="{Binding Icon}"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                          StrokeThickness="1.8"
                                          Fill="Transparent"
                                          Stretch="Uniform"
                                          Width="20" Height="20"
                                          VerticalAlignment="Center" Margin="4,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Label}"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.IsSidebarExpanded, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Bottom Actions -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,12">

                        <!-- Controllers Battery -->
                        <ItemsControl ItemsSource="{Binding BatteryItems}"
                                      Margin="0,0,0,8"
                                      Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:SidebarBatteryItem">
                                        <Border Margin="16,2,16,2" Padding="8,4"
                                                CornerRadius="6"
                                                Background="{DynamicResource SurfaceAltBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="0" Data="{Binding Icon}"
                                                      Stroke="{StaticResource PrimaryBrush}"
                                                      StrokeThickness="1.8" Fill="Transparent"
                                                      Stretch="Uniform" Width="18" Height="18"
                                                      VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                           FontSize="12" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Margin="8,0,0,0" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.IsSidebarExpanded, Converter={StaticResource BoolToVis}}"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <Path Data="{StaticResource BatteryChargingIcon}"
                                                          Stroke="{StaticResource PrimaryBrush}"
                                                          StrokeThickness="1.8" Fill="Transparent"
                                                          Stretch="Uniform" Width="14" Height="14"
                                                          VerticalAlignment="Center"
                                                          Visibility="{Binding IsCharging, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Text="{Binding BatteryText}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               Margin="4,0,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Command="{Binding ScanControllersCommand}"
                                Style="{StaticResource SidebarActionButtonStyle}">
                            <StackPanel Orientation="Horizontal" Margin="20,0">
                                <Path Data="{StaticResource SearchIcon}"
                                      Stroke="{DynamicResource TextSecondaryBrush}"
                                      StrokeThickness="1.8" Fill="Transparent"
                                      Stretch="Uniform" Width="18" Height="18"
                                      VerticalAlignment="Center"/>
                                <TextBlock Text="Buscar" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="12,0,0,0"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Center"
                          Background="Transparent" IsEnabled="False"/>

            <!-- Main Content Area -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Border Grid.Row="0" x:Name="TitleBar"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="0,8,0,0"
                        MouseLeftButtonDown="TitleBar_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Sidebar Toggle -->
                        <Button Grid.Column="0" Command="{Binding ToggleSidebarCommand}"
                                Width="40" Height="32"
                                Style="{StaticResource WindowControlButtonStyle}">
                            <Path Data="{StaticResource MenuIcon}"
                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                  StrokeThickness="1.8" Fill="Transparent"
                                  Stretch="Uniform" Width="18" Height="18"/>
                        </Button>

                        <!-- Back / Forward Navigation -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="4,0,12,0">
                            <Button Command="{Binding GoBackCommand}"
                                    Width="32" Height="32"
                                    Style="{StaticResource WindowControlButtonStyle}">
                                <Path Data="{StaticResource ChevronLeftIcon}"
                                      Stroke="{DynamicResource TextSecondaryBrush}"
                                      StrokeThickness="1.8" Fill="Transparent"
                                      Stretch="Uniform" Width="14" Height="14"/>
                            </Button>
                            <Button Command="{Binding GoForwardCommand}"
                                    Width="32" Height="32"
                                    Style="{StaticResource WindowControlButtonStyle}">
                                <Path Data="{StaticResource ChevronRightIcon}"
                                      Stroke="{DynamicResource TextSecondaryBrush}"
                                      StrokeThickness="1.8" Fill="Transparent"
                                      Stretch="Uniform" Width="14" Height="14"/>
                            </Button>
                        </StackPanel>

                        <TextBlock Grid.Column="2" Text="{Binding SelectedItem.Label}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,0,0"/>

                        <!-- Window Controls -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <Button x:Name="MinimizeButton" Click="MinimizeClick"
                                    Width="46" Height="32"
                                    Style="{StaticResource WindowControlButtonStyle}">
                                <Path Data="{StaticResource MinusIcon}"
                                      Stroke="{DynamicResource TextSecondaryBrush}"
                                      StrokeThickness="1.8" Fill="Transparent"
                                      Stretch="Uniform" Width="12" Height="12"/>
                            </Button>
                            <Button x:Name="MaximizeButton" Click="MaximizeClick"
                                    Width="46" Height="32"
                                    Style="{StaticResource WindowControlButtonStyle}">
                                <Path x:Name="MaximizeIcon" Data="{StaticResource MaximizeIcon}"
                                      Stroke="{DynamicResource TextSecondaryBrush}"
                                      StrokeThickness="1.8" Fill="Transparent"
                                      Stretch="Uniform" Width="12" Height="12"/>
                            </Button>
                            <Button x:Name="CloseButton" Click="CloseClick"
                                    Width="46" Height="32"
                                    Style="{StaticResource WindowCloseButtonStyle}">
                                <Path x:Name="CloseIcon" Data="{StaticResource CloseIcon}"
                                      Stroke="{DynamicResource TextSecondaryBrush}"
                                      StrokeThickness="1.8" Fill="Transparent"
                                      Stretch="Uniform" Width="12" Height="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Dynamic Content -->
                <ContentControl Grid.Row="1" x:Name="MainContent"
                                VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                Focusable="False"/>

                <!-- Notification Overlay -->
                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding Notifications}"
                              VerticalAlignment="Bottom"
                              HorizontalAlignment="Right"
                              Margin="0,0,16,16"
                              Focusable="False"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="10"
                                    Padding="16,12" Margin="0,0,0,8"
                                    Effect="{StaticResource CardShadow}"
                                    MinWidth="280" MaxWidth="360"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TranslateTransform X="400"/>
                                </Border.RenderTransform>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                             Fill="{StaticResource PrimaryBrush}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Title}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding Message}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </Grid>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                                 From="400" To="0" Duration="0:0:0.4"
                                                                 EasingFunction="{StaticResource SmoothEaseOut}"/>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0" To="1" Duration="0:0:0.3"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Tray Icon (not rendered visually) -->
            <tb:TaskbarIcon x:Name="TrayIcon"
                            ToolTipText="NovaPad"
                            Visibility="Collapsed"
                            TrayMouseDoubleClick="ShowWindowFromTray">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Mostrar NovaPad" Click="TrayShowClick"/>
                        <Separator/>
                        <MenuItem Header="Salir" Click="TrayExitClick"/>
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
        </Grid>
    </Border>
</Window>
