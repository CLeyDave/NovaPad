<UserControl x:Class="NovaPad.WPF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NovaPad.WPF.ViewModels"
             xmlns:services="clr-namespace:NovaPad.WPF.Services"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}">

    <ScrollViewer Style="{StaticResource ModernScrollViewer}" Padding="24">
        <StackPanel MaxWidth="560">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Border Width="40" Height="40" CornerRadius="10"
                        Background="{DynamicResource SurfaceAltBrush}">
                    <Path Data="{StaticResource SettingsIcon}"
                          Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8"
                          Fill="Transparent" Stretch="Uniform" Width="20" Height="20"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Title]}"
                           Style="{StaticResource SectionTitleStyle}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>

            <!-- GENERAL -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_General]}"
                               FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_StartWithWindows]}"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_StartWithWindowsDesc]}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding StartWithWindows}"
                                      Style="{StaticResource ModernToggleSwitch}" VerticalAlignment="Center"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,8,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_MinimizeToTray]}"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_MinimizeToTrayDesc]}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding MinimizeToTray}"
                                      Style="{StaticResource ModernToggleSwitch}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- APARIENCIA -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Appearance]}"
                               FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Theme]}"
                                   FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  SelectedItem="{Binding Theme, Mode=TwoWay}"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  MinWidth="160" HorizontalAlignment="Left">
                            <ComboBox.ItemsSource>
                                <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=System.Runtime">
                                    <sys:String>Oscuro</sys:String>
                                    <sys:String>Claro</sys:String>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Language]}"
                                   FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  SelectedItem="{Binding Language, Mode=TwoWay}"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  MinWidth="160" HorizontalAlignment="Left" Margin="0,8,0,0">
                            <ComboBox.ItemsSource>
                                <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=System.Runtime">
                                    <sys:String>Español</sys:String>
                                    <sys:String>English</sys:String>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- NOTIFICACIONES -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Notifications]}"
                               FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Duration]}"
                                   FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Slider Value="{Binding NotificationDuration}" Minimum="1" Maximum="6" Width="100"
                                     TickFrequency="0.5" IsSnapToTickEnabled="True"
                                     Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock Text="{Binding NotificationDuration, StringFormat={}{0:F1}s}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="8,0,0,0" Width="40"/>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,8,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_BatteryAlert]}"
                                   FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                             <Slider Value="{Binding BatteryWarningThreshold}" Minimum="5" Maximum="50" Width="100"
                                     TickFrequency="5" IsSnapToTickEnabled="True"
                                     Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock Text="{Binding BatteryWarningThreshold, StringFormat={}{0}%}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="8,0,0,0" Width="40"/>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,8,0,8"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_ConnectionNotifs]}"
                                   FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding ShowConnectionNotifications}" Style="{StaticResource ModernToggleSwitch}"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_BatteryNotifs]}"
                                   FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding ShowBatteryNotifications}" Style="{StaticResource ModernToggleSwitch}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ACERCA DE -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_About]}"
                               FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Version]}"
                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding AppVersion}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Build]}"
                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding BuildDate}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,4,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ACTUALIZACIONES -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="ACTUALIZACIONES" FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding Updater.StatusText}"
                               FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <ProgressBar Value="{Binding Updater.DownloadProgress, Mode=OneWay}"
                                 Maximum="100" Height="4" Minimum="0"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 Background="{DynamicResource SurfaceAltBrush}"
                                 BorderThickness="0" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Buscar actualizaciones"
                                Command="{Binding CheckForUpdatesCommand}"
                                IsEnabled="{Binding Updater.CanCheck}"
                                Background="{StaticResource PrimaryBrush}"
                                Foreground="White" BorderThickness="0"
                                Padding="14,6" FontSize="13"/>
                        <Button Content="Descargar"
                                Command="{Binding DownloadUpdateCommand}"
                                IsEnabled="{Binding Updater.CanDownload}"
                                Background="{StaticResource SecondaryBrush}"
                                Foreground="White" BorderThickness="0"
                                Padding="14,6" FontSize="13" Margin="8,0,0,0"/>
                        <Button Content="Instalar"
                                Command="{Binding InstallUpdateCommand}"
                                IsEnabled="{Binding Updater.CanInstall}"
                                Background="{StaticResource ConnectedBrush}"
                                Foreground="White" BorderThickness="0"
                                Padding="14,6" FontSize="13" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>