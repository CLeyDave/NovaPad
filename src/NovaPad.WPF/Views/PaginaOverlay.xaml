<UserControl x:Class="NovaPad.WPF.Views.PaginaOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NovaPad.WPF.ViewModels"
             xmlns:svc="clr-namespace:NovaPad.WPF.Services"
             xmlns:conv="clr-namespace:NovaPad.WPF.Converters"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DataContext="{d:DesignInstance vm:AdminOverlayVm}">
    <UserControl.Resources>
        <conv:HexToBrushConverter x:Key="HexBrush"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Width="200" Margin="24,24,0,24" CornerRadius="10"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="MANDOS" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextDisabledBrush}"
                           Margin="16,14,16,8"/>

                <ListBox ItemsSource="{Binding ControllerOptions}"
                         SelectedItem="{Binding SelectedController, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent"/>
                    </ListBox.Resources>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Margin" Value="4,2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                BorderThickness="0" Margin="{TemplateBinding Margin}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource PrimaryBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource SurfaceAltBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐" FontSize="13" Margin="0,0,8,0"
                                           Visibility="{Binding EsGlobal, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="🎮" FontSize="11" Margin="0,0,8,0"
                                           Visibility="{Binding EsGlobal, Converter={StaticResource BoolToVisInverted}}"/>
                                <TextBlock Text="{Binding Nombre}" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Separator Margin="12,4" Opacity="0.2"/>

                <Border Margin="12,8,12,12" Padding="10,8" CornerRadius="6"
                        Background="{DynamicResource SurfaceAltBrush}">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusText}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="Iniciar" Command="{Binding StartLayerCommand}"
                                    Background="{StaticResource PrimaryBrush}"
                                    Foreground="White" BorderThickness="0" Padding="10,4" FontSize="11"
                                    Visibility="{Binding CanStart, Converter={StaticResource BoolToVis}}"/>
                            <Button Content="Detener" Command="{Binding StopLayerCommand}"
                                    Background="{StaticResource ErrorBrush}"
                                    Foreground="White" BorderThickness="0" Padding="10,4" FontSize="11"
                                    Margin="6,0,0,0"
                                    Visibility="{Binding CanStop, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Column="1" Padding="24,24,24,24">
            <StackPanel>

                <!-- General -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="GENERAL" FontSize="10"
                                   Foreground="{DynamicResource TextDisabledBrush}" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_AutoStart]}"
                                           FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_AutoStartDesc]}"
                                           FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding AutoStart}" Style="{StaticResource ModernToggleSwitch}"/>
                        </Grid>

                        <Separator Margin="0,4" Opacity="0.3"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_Status]}"
                                           FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Per-controller badge -->
                <Border Margin="0,0,0,12" Padding="12,8" CornerRadius="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        Visibility="{Binding IsPerController, Converter={StaticResource BoolToVis}}">
                    <TextBlock FontSize="12" Foreground="{DynamicResource PrimaryBrush}">
                        <Run Text="Configurando: "/>
                        <Run Text="{Binding SelectedController.Nombre, FallbackValue=''}" FontWeight="SemiBold"/>
                        <Run Text=" — Los cambios solo afectan a este mando"/>
                    </TextBlock>
                </Border>

                <!-- Apariencia (global: opacity, scale, font; per-card: accent, bg, style) -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="APARIENCIA" FontSize="10"
                                   Foreground="{DynamicResource TextDisabledBrush}" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_Opacity]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Value="{Binding Opacity}" Minimum="0.2" Maximum="1" TickFrequency="0.1"
                                    IsSnapToTickEnabled="True" Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock Grid.Column="2" Text="{Binding Opacity, StringFormat={}{0:F1}}" FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,8"
                              Visibility="{Binding IsPerController, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_HudScale]}"
                                        FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Value="{Binding Scale}" Minimum="0.5" Maximum="2" TickFrequency="0.1"
                                    IsSnapToTickEnabled="True" Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock Grid.Column="2" Text="{Binding Scale, StringFormat={}{0:F1}x}" FontSize="13"
                                        Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_AccentColor]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <ItemsControl Grid.Column="1" ItemsSource="{Binding PaletteAccent}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="24" Height="24" CornerRadius="12" Margin="0,0,5,0" Cursor="Hand"
                                                BorderBrush="#555" BorderThickness="1" Background="{Binding Converter={StaticResource HexBrush}}">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.SetAccentColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_BgColor]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <ItemsControl Grid.Column="1" ItemsSource="{Binding PaletteBg}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="24" Height="24" CornerRadius="12" Margin="0,0,5,0" Cursor="Hand"
                                                BorderBrush="#555" BorderThickness="1" Background="{Binding Converter={StaticResource HexBrush}}">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.SetBgColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_FontSize]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Value="{Binding FontScale}" Minimum="0.5" Maximum="2" TickFrequency="0.1"
                                    IsSnapToTickEnabled="True" Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock Grid.Column="2" Text="{Binding FontScale, StringFormat={}{0:F1}x}" FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Estilo tarjeta"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding EstiloLabels}" SelectedIndex="{Binding EstiloTarjetaIdx}"
                                      Style="{StaticResource ModernComboBoxStyle}" HorizontalAlignment="Left" MinWidth="140"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- Notification Style -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12"
                        Visibility="{Binding IsPerController, Converter={StaticResource BoolToVisInverted}}">
                    <StackPanel>
                        <TextBlock Text="ESTILO AVISOS" FontSize="10" Foreground="{DynamicResource TextDisabledBrush}" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Estilo"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding EstiloAvisoLabels}" SelectedIndex="{Binding EstiloAvisoIdx}"
                                      Style="{StaticResource ModernComboBoxStyle}" HorizontalAlignment="Left" MinWidth="140"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- HUD Position -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12"
                        Visibility="{Binding IsPerController, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="POSICION HUD" FontSize="10" Foreground="{DynamicResource TextDisabledBrush}" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_Anchor]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding AnchorLabels}" SelectedIndex="{Binding HudAnchorIdx}"
                                      Style="{StaticResource ModernComboBoxStyle}" HorizontalAlignment="Left" MinWidth="160"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_OffsetX]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Value="{Binding HudOffX}" Minimum="-500" Maximum="500" TickFrequency="10"
                                    IsSnapToTickEnabled="True" Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock Grid.Column="2" Text="{Binding HudOffX, StringFormat={}{0:F0}px}" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_OffsetY]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Value="{Binding HudOffY}" Minimum="-500" Maximum="500" TickFrequency="10"
                                    IsSnapToTickEnabled="True" Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock Grid.Column="2" Text="{Binding HudOffY, StringFormat={}{0:F0}px}" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- HUD Elements -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="ELEMENTOS HUD" FontSize="10" Foreground="{DynamicResource TextDisabledBrush}" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_ShowBattery]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding ShowBattery}" Style="{StaticResource ModernToggleSwitch}"/>
                        </Grid>
                        <Grid Margin="0,0,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_ShowLatency]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding ShowLatency}" Style="{StaticResource ModernToggleSwitch}"/>
                        </Grid>
                        <Grid Margin="0,0,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_ShowPollingRate]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding ShowPolling}" Style="{StaticResource ModernToggleSwitch}"/>
                        </Grid>
                        <Grid Margin="0,0,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_ShowProfile]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding ShowProfile}" Style="{StaticResource ModernToggleSwitch}"/>
                        </Grid>
                        <Grid Margin="0,0,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_ShowConnection]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding ShowConnection}" Style="{StaticResource ModernToggleSwitch}"/>
                        </Grid>
                        <Grid Margin="0,0,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_ShowFps]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding ShowFps}" Style="{StaticResource ModernToggleSwitch}"/>
                        </Grid>
                        <Grid Margin="0,0,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_ShowClock]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding ShowClock}" Style="{StaticResource ModernToggleSwitch}"/>
                        </Grid>
                        <Grid Margin="0,0,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_ShowControllerType]}"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding ShowType}" Style="{StaticResource ModernToggleSwitch}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button Content="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[OverlaySettings_TestNotification]}"
                        Command="{Binding TestAlertCommand}" Background="{StaticResource PrimaryBrush}"
                        Foreground="White" BorderThickness="0" Padding="14,6" FontSize="13"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
