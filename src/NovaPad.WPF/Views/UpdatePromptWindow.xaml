<Window x:Class="NovaPad.WPF.Views.UpdatePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Actualizacion disponible"
        Height="220" Width="460"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        FontSize="14">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>
    <StackPanel Margin="24,20,24,20">
        <TextBlock Text="Nueva version disponible" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <TextBlock x:Name="VersionText" Text="NovaPad X.X.X esta disponible." FontSize="14" Foreground="#666" Margin="0,0,0,18"/>
        <TextBlock Text="Que deseas hacer?" FontSize="14" Foreground="#666" Margin="0,0,0,20"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="BtnDownloadInstall" Content="Descargar e instalar" Click="BtnDownloadInstall_Click" IsDefault="True" Width="180"/>
            <Button x:Name="BtnDownload" Content="Solo descargar" Click="BtnDownload_Click" Width="130"/>
            <Button x:Name="BtnLater" Content="Mas tarde" Click="BtnLater_Click" Width="100"/>
        </StackPanel>
    </StackPanel>
</Window>
