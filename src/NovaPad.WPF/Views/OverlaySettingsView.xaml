<UserControl x:Class="NovaPad.WPF.Views.OverlaySettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NovaPad.WPF.ViewModels"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DataContext="{d:DesignInstance vm:OverlaySettingsViewModel}">

    <ScrollViewer Style="{StaticResource ModernScrollViewer}" Padding="24">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <Border Width="40" Height="40" CornerRadius="10"
                        Background="{DynamicResource SurfaceAltBrush}"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                    <Path Data="{StaticResource LayersIcon}"
                          Stroke="{StaticResource PrimaryBrush}"
                          StrokeThickness="1.8" Fill="Transparent"
                          Stretch="Uniform" Width="22" Height="22"
                          VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Overlay" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Configuración de la superposición" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- General -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="GENERAL" FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Auto-iniciar Overlay" FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Iniciar NovaPad.Overlay.exe al abrir la app" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" IsChecked="{Binding AutoStartOverlay}"
                                  Focusable="False" VerticalAlignment="Center"/>
                    </Grid>

                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,8,0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Estado" FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding OverlayStatusText}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Iniciar" Command="{Binding StartOverlayCommand}"
                                    Background="{StaticResource PrimaryBrush}"
                                    Foreground="White" BorderThickness="0"
                                    Padding="14,6" Margin="0,0,8,0"
                                    FontSize="13" FontWeight="Medium" Cursor="Hand"
                                    Visibility="{Binding CanStart, Converter={StaticResource BoolToVis}}"/>
                            <Button Content="Detener" Command="{Binding StopOverlayCommand}"
                                    Background="{StaticResource ErrorBrush}"
                                    Foreground="White" BorderThickness="0"
                                    Padding="14,6" FontSize="13" FontWeight="Medium" Cursor="Hand"
                                    Visibility="{Binding CanStop, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Apariencia -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="APARIENCIA" FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Opacidad" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Slider Grid.Column="1" Value="{Binding Opacity}" Minimum="0.2" Maximum="1" Width="200"
                                TickFrequency="0.1" IsSnapToTickEnabled="True"
                                HorizontalAlignment="Left"/>
                        <TextBlock Grid.Column="2" Text="{Binding Opacity, StringFormat={}{0:F1}}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" Width="30"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Mostrar notificaciones" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <CheckBox Grid.Column="2" IsChecked="{Binding ShowNotifications}"
                                  Focusable="False" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Posición del HUD -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="POSICIÓN DEL HUD" FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Anclaje" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding AnchorLabels}"
                                  SelectedIndex="{Binding HudAnchorIndex}"
                                  HorizontalAlignment="Left" MinWidth="180"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Desplazamiento X" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Slider Grid.Column="1" Value="{Binding HudOffsetX}" Minimum="-500" Maximum="500"
                                Width="200" HorizontalAlignment="Left"
                                TickFrequency="10" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="2" Text="{Binding HudOffsetX, StringFormat={}{0:F0}px}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" Width="60"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Desplazamiento Y" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Slider Grid.Column="1" Value="{Binding HudOffsetY}" Minimum="-500" Maximum="500"
                                Width="200" HorizontalAlignment="Left"
                                TickFrequency="10" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="2" Text="{Binding HudOffsetY, StringFormat={}{0:F0}px}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" Width="60"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Posición de Notificaciones -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="POSICIÓN DE NOTIFICACIONES" FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Anclaje" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding AnchorLabels}"
                                  SelectedIndex="{Binding NotificationAnchorIndex}"
                                  HorizontalAlignment="Left" MinWidth="180"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Desplazamiento X" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Slider Grid.Column="1" Value="{Binding NotificationOffsetX}" Minimum="-500" Maximum="500"
                                Width="200" HorizontalAlignment="Left"
                                TickFrequency="10" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="2" Text="{Binding NotificationOffsetX, StringFormat={}{0:F0}px}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" Width="60"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Desplazamiento Y" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Slider Grid.Column="1" Value="{Binding NotificationOffsetY}" Minimum="-500" Maximum="500"
                                Width="200" HorizontalAlignment="Left"
                                TickFrequency="10" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="2" Text="{Binding NotificationOffsetY, StringFormat={}{0:F0}px}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" Width="60"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Elementos del HUD -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="ELEMENTOS DEL HUD" FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Mostrar batería" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding ShowBattery}" Focusable="False"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Mostrar latencia" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding ShowLatency}" Focusable="False"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Mostrar polling rate" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding ShowPollingRate}" Focusable="False"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Mostrar perfil activo" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding ShowProfileName}" Focusable="False"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Mostrar estado de conexión" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding ShowConnectionStatus}" Focusable="False"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Mostrar FPS (debug)" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding ShowFps}" Focusable="False"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Mostrar tipo de mando" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding ShowControllerType}" Focusable="False"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
