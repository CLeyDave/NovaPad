<UserControl x:Class="NovaPad.WPF.Views.ControllerDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NovaPad.WPF.ViewModels"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DataContext="{d:DesignInstance vm:ControllerDetailViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header (always visible) -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="16,16,16,0" Padding="16">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12"
                            Background="{DynamicResource SurfaceAltBrush}" VerticalAlignment="Center">
                        <Path Data="{StaticResource GamepadIcon}"
                              Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8"
                              Fill="Transparent" Stretch="Uniform" Width="24" Height="24"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="MANDO" FontSize="11"
                                   Foreground="{DynamicResource TextDisabledBrush}"/>
                        <ComboBox ItemsSource="{Binding ConnectedControllers}"
                                  SelectedItem="{Binding SelectedController, Mode=TwoWay}"
                                  DisplayMemberPath="EffectiveName"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  MinWidth="200" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12,6"
                                Background="{DynamicResource SurfaceAltBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Lat: " FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Latency}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" MinWidth="40"/>
                            </Grid>
                        </Border>

                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12,6"
                                Background="{DynamicResource SurfaceAltBrush}" Margin="8,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Poll: " FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding PollingRate}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" MinWidth="50"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Style="{StaticResource ModernScrollViewer}" Margin="16,0,16,16">
            <StackPanel>
                <!-- WebView2 Gamepad Tester -->
                <wv2:WebView2 x:Name="GamepadWebView" Margin="0,16,0,0"
                              Height="300" VerticalAlignment="Stretch"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
