<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Palette -->
    <Color x:Key="PrimaryColor">#00BCD4</Color>
    <Color x:Key="PrimaryDarkColor">#00838F</Color>
    <Color x:Key="PrimaryLightColor">#4DD0E1</Color>
    <Color x:Key="SecondaryColor">#9C27B0</Color>
    <Color x:Key="SecondaryDarkColor">#7B1FA2</Color>
    <Color x:Key="SecondaryLightColor">#CE93D8</Color>

    <!-- Dark Theme -->
    <Color x:Key="DarkBackground">#0D0D0D</Color>
    <Color x:Key="DarkSurface">#1A1A1A</Color>
    <Color x:Key="DarkSurfaceAlt">#242424</Color>
    <Color x:Key="DarkBorder">#333333</Color>
    <Color x:Key="DarkTextPrimary">#F5F5F5</Color>
    <Color x:Key="DarkTextSecondary">#9E9E9E</Color>
    <Color x:Key="DarkTextDisabled">#616161</Color>

    <!-- Light Theme -->
    <Color x:Key="LightBackground">#F5F5F5</Color>
    <Color x:Key="LightSurface">#FFFFFF</Color>
    <Color x:Key="LightSurfaceAlt">#E8E8E8</Color>
    <Color x:Key="LightBorder">#D0D0D0</Color>
    <Color x:Key="LightTextPrimary">#1A1A1A</Color>
    <Color x:Key="LightTextSecondary">#757575</Color>
    <Color x:Key="LightTextDisabled">#BDBDBD</Color>

    <!-- Status Colors -->
    <Color x:Key="StatusConnected">#4CAF50</Color>
    <Color x:Key="StatusDisconnected">#F44336</Color>
    <Color x:Key="StatusWarning">#FF9800</Color>
    <Color x:Key="StatusBatteryLow">#F44336</Color>
    <Color x:Key="StatusCharging">#4CAF50</Color>
    <Color x:Key="StatusBluetooth">#2196F3</Color>
    <Color x:Key="StatusUsb">#9E9E9E</Color>

    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#00BCD4" Offset="0.0"/>
        <GradientStop Color="#9C27B0" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#1A1A1A" Offset="0.0"/>
        <GradientStop Color="#0D0D0D" Offset="1.0"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="SecondaryDarkBrush" Color="{StaticResource SecondaryDarkColor}"/>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource DarkBackground}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource DarkSurface}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource DarkSurfaceAlt}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource DarkBorder}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource DarkTextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource DarkTextSecondary}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource DarkTextDisabled}"/>

    <SolidColorBrush x:Key="ConnectedBrush" Color="{StaticResource StatusConnected}"/>
    <SolidColorBrush x:Key="DisconnectedBrush" Color="{StaticResource StatusDisconnected}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource StatusWarning}"/>
    <SolidColorBrush x:Key="BatteryLowBrush" Color="{StaticResource StatusBatteryLow}"/>
    <SolidColorBrush x:Key="ChargingBrush" Color="{StaticResource StatusCharging}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource StatusDisconnected}"/>
</ResourceDictionary>
